<% layout('layouts/boilerplate')%>

    <div class="row">
        <h1 class="text-center">Edit Recipe</h1>
        <div class="col-6 offset-3">
            <form action="/recipes/<%=recipe._id%>?_method=PUT" method="POST" novalidate class="validated-form">
                <div class="mb-3">
                    <label class="form-label" for="name">Name</label>
                    <input class="form-control" type="text" id="name" name="recipe[name]" value="<%=recipe.name%>"
                        required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control" type="text" id="title" name="recipe[title]" value="<%=recipe.title%>"
                        required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Image URL</label>
                    <input class="form-control" type="text" id="image" name="recipe[image]" value="<%=recipe.image%>"
                        required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="formula">Formula</label>
                    <input class="form-control" type="text" id="formula" name="recipe[formula]"
                        value="<%=recipe.formula%>" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_1">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_1" name="recipe[ingredient_1]"
                        value="<%=recipe.ingredient_1%>" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_2">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_2" name="recipe[ingredient_2]"
                        value="<%=recipe.ingredient_2%>" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_3">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_3" name="recipe[ingredient_3]"
                        value="<%=recipe.ingredient_3%>" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_4">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_4" name="recipe[ingredient_4]"
                        value="<%=recipe.ingredient_4%>">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_5">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_5" name="recipe[ingredient_5]"
                        value="<%=recipe.ingredient_5%>" >
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_6">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_6" name="recipe[ingredient_6]"
                        value="<%=recipe.ingredient_6%>">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_7">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_7" name="recipe[ingredient_7]"
                        value="<%=recipe.ingredient_7%>">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" type="text" id="description" name="recipe[description]" required>
                        <%=recipe.description%>
                    </textarea>
                </div>
                <div class="mb-3">
                    <button class="btn btn-info">Update Recipe</button>
                </div>
            </form>
            <a href="/recipes/<%= recipe._id%>" class="text-decoration-none">Back to Recipe</a>
        </div>
    </div>