<% layout('layouts/boilerplate')%>

    <div class="row">
        <h1 class="text-center">New Recipe</h1>
        <div class="col-6 offset-3">
            <form action="/recipes" method="POST" novalidate class="validated-form">
                <div class="mb-3">
                    <label class="form-label" for="name">Name</label>
                    <input class="form-control" type="text" id="name" name="recipe[name]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control" type="text" id="title" name="recipe[title]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Image URL</label>
                    <input class="form-control" type="text" id="image" name="recipe[image]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="formula">Formula</label>
                    <input class="form-control" type="text" id="formula" name="recipe[formula]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_1">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_1" name="recipe[ingredient_1]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_2">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_2" name="recipe[ingredient_2]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_3">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_3" name="recipe[ingredient_3]" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_4">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_4" name="recipe[ingredient_4]" required>
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_5">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_5" name="recipe[ingredient_5]" >
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_6">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_6" name="recipe[ingredient_6]" >
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ingredient_7">Ingredients</label>
                    <input class="form-control" type="text" id="ingredient_7" name="recipe[ingredient_7]">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" type="text" id="description" name="recipe[description]" required>
                    </textarea>
                    <!-- <div class="valid-feedback">
                        Looks good!
                    </div> -->
                </div>
                <div class="mb-3">
                    <button class="btn btn-success">Add Recipe</button>
                </div>
            </form>
        </div>
        <a href="/recipes" class="text-decoration-none">All Recipes</a>
    </div>